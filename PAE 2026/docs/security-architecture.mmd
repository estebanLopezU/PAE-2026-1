graph TB
    subgraph Cliente["🌐 Cliente (Frontend - React/Vite)"]
        A[Navegador Web]
        AC[AuthContext.jsx\nGestión de tokens]
        API[api.js\nInterceptor HTTP]
        DASH[Dashboard.jsx\nReportes.jsx\nHeaders Bearer]
    end

    subgraph Backend["🛡️ Backend (FastAPI - Python)"]
        direction TB
        RL[Rate Limiter\n120 req/min]
        AUTH[security.py\nAutenticación JWT]
        ROLE[Control de Roles\nadmin / analyst / viewer]
        EP[Endpoints API]
    end

    subgraph Token["🔑 JWT Token Service"]
        AT[Access Token\nExpira: 120 min\ntype=access]
        RT[Refresh Token\nExpira: 10080 min\ntype=refresh]
    end

    subgraph Config["⚙️ Configuración"]
        ENV[.env / config.py]
        SEC[AUTH_ENABLED\nJWT_SECRET_KEY\nRATE_LIMIT_PER_MINUTE]
        USERS[Usuarios Demo\nadmin@xroad.co\nanalyst@xroad.co]
    end

    subgraph Storage["💾 Persistencia"]
        DB[(PostgreSQL / SQLite\nxroad_colombia)]
    end

    %% Flujo de autenticación
    A -->|POST /auth/login| AUTH
    AUTH -->|Valida credenciales| USERS
    AUTH -->|Genera tokens| AT
    AUTH -->|Genera tokens| RT
    AT -->|Almacena| AC
    RT -->|Almacena| AC

    %% Flujo de peticiones autenticadas
    DASH -->|Authorization: Bearer AT| RL
    RL -->|Si quota ok| AUTH
    AUTH -->|decode_token + get_current_user| ROLE
    ROLE -->|require_admin / require_analyst| EP
    EP -->|CRUD| DB

    %% Refresh token flow
    API -->|HTTP 401 → POST /auth/refresh| AUTH
    AUTH -->|Valida refresh_token| RT
    AUTH -->|Nuevo access_token| AT
    AT -->|Actualiza en frontend| AC

    %% Config
    ENV -->|Lee variables| SEC
    SEC -->|Configura| AUTH
    SEC -->|Configura| RL
    SEC -->|Configura| AT
    SEC -->|Configura| RT